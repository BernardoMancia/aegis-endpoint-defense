# =============================================================
# AEGIS SIEM & EDR Platform - Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores reais
# =============================================================

# --- Segurança ---
AEGIS_API_TOKEN=mude-este-token-secreto-agora
AEGIS_SECRET_KEY=chave-secreta-flask-muito-longa-e-aleatoria

# --- Servidor ---
AEGIS_PORT=5000
AEGIS_DEBUG=false
AEGIS_HOST=0.0.0.0

# --- Banco de Dados ---
# Caminho dentro do container Docker (/app/data/aegis.db)
DATABASE_PATH=/app/data/aegis.db

# --- Integrações AI (opcional) ---
# Configure ao menos uma para usar o Chat Assistant
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=AIzaSy...

# --- Notificações (opcional) ---
# Webhook do Slack para alertas CRITICAL
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
